STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_VERIFY_TOKEN=change-me
APP_SECRET=change-me
BASE_URL=https://app-xxx.cleverapps.io
# POSTGRESQL_ADDON_URI est injectée automatiquement sur Clever Cloud
# Id d'abonnement webhook (GET /push_subscriptions) : protège le webhook des POST forgés
STRAVA_SUBSCRIPTION_ID=
# Notifications push web (npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:toi@example.com
# Seuil plancher (m) de détection des sauts GPS (défaut 2000)
# GPS_JUMP_MIN_M=2000
